ARG APP_VERSION=dev

# Pins build stages to native platform so multi-arch skips QEMU
ARG BUILDPLATFORM=linux/amd64

# Generates proto code in-image matching make proto exactly
FROM --platform=$BUILDPLATFORM golang:alpine AS proto-builder

COPY --from=bufbuild/buf:latest /usr/local/bin/buf /usr/local/bin/buf

WORKDIR /app
COPY go.mod go.sum buf.yaml buf.gen.yaml buf.lock ./
COPY proto/ ./proto/

# Materializes schema, generates, injects gorm tags and store
RUN mkdir -p web/discopanel/static pkg/proto web/discopanel/src/lib/proto \
    && go tool protogorm -options proto \
    && buf generate --exclude-path proto/protogorm \
    && buf build -o - | go tool protogorm -support pkg/proto -store internal/db/store.gen.go:db -inject pkg/proto

FROM --platform=$BUILDPLATFORM node:alpine AS frontend-builder

ARG APP_VERSION
ENV APP_VERSION=${APP_VERSION}

WORKDIR /app/web/discopanel

COPY web/discopanel/package*.json ./
RUN npm ci

COPY web/discopanel/ ./
COPY --from=proto-builder /app/web/discopanel/src/lib/proto ./src/lib/proto/
COPY --from=proto-builder /app/web/discopanel/static/schemav1.yaml ./static/

RUN npm run build

FROM golang:alpine AS backend-builder

ARG APP_VERSION
ENV APP_VERSION=${APP_VERSION}

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
COPY --from=proto-builder /app/pkg/proto ./pkg/proto/
COPY --from=proto-builder /app/internal/db/store.gen.go ./internal/db/store.gen.go
COPY --from=frontend-builder /app/web/discopanel/build ./web/discopanel/build

RUN CGO_ENABLED=1 GOOS=linux go build -a -installsuffix cgo -o discopanel ./cmd/discopanel

FROM alpine:latest

ARG APP_VERSION
ENV APP_VERSION=${APP_VERSION}

RUN apk --no-cache add ca-certificates sqlite-libs

WORKDIR /app

COPY --from=backend-builder /app/discopanel .
COPY config.example.yaml ./

#RUN mkdir -p data/servers backups tmp

EXPOSE 8080

CMD ["./discopanel"]