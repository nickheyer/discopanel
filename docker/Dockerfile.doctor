FROM golang:alpine AS builder

WORKDIR /build

# Copy go mod files first for caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY cmd/doctor/ ./cmd/doctor/
COPY pkg/ ./pkg/

# Build the binary
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /doctor ./cmd/doctor

FROM alpine:latest

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /doctor /usr/local/bin/discopanel-doctor

ENTRYPOINT ["/usr/local/bin/discopanel-doctor"]
